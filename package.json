{
  "name": "@mordn/chat-widget",
  "version": "0.8.0",
  "description": "A customizable AI chat widget for React applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.mjs",
      "require": "./dist/db/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.mjs",
      "require": "./dist/schema/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./server/drizzle": {
      "types": "./dist/server/drizzle/index.d.ts",
      "import": "./dist/server/drizzle/index.mjs",
      "require": "./dist/server/drizzle/index.js"
    },
    "./server/supabase": {
      "types": "./dist/server/supabase/index.d.ts",
      "import": "./dist/server/supabase/index.mjs",
      "require": "./dist/server/supabase/index.js"
    }
  },
  "bin": {
    "chat-widget": "./dist/cli/init.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup && npx @tailwindcss/cli -i src/styles.src.css -o dist/styles.css --minify && node scripts/scope-css.js",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ai": "^5.0.0 || ^6.0.0",
    "drizzle-orm": "^0.44.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "postgres": "^3.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@supabase/supabase-js": "^2.86.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "nanoid": "^5.1.6",
    "react-syntax-highlighter": "^15.6.6",
    "server-only": "^0.0.1",
    "shiki": "^3.19.0",
    "streamdown": "^1.3.0",
    "tailwind-merge": "^3.3.1",
    "use-stick-to-bottom": "^1.1.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.22",
    "drizzle-kit": "^0.31.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.0.0",
    "typescript": "^5"
  },
  "keywords": [
    "react",
    "chat",
    "widget",
    "ai",
    "chatbot",
    "next.js",
    "drizzle",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arnavv-guptaa/chat-widget"
  },
  "homepage": "https://github.com/arnavv-guptaa/chat-widget#readme",
  "bugs": {
    "url": "https://github.com/arnavv-guptaa/chat-widget/issues"
  }
}
